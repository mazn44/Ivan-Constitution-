        <div id="passwordModalContent" class="bg-white dark:bg-ivan-darkCard border border-ivan-red/30 dark:border-ivan-red/50 rounded-3xl p-8 max-w-sm w-full transform scale-95 transition-transform duration-300 shadow-2xl text-center">
            <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-ivan-red to-red-900 flex items-center justify-center shadow-lg shadow-ivan-red/30 mb-4">
                <i class="fa-solid fa-shield-halved text-white text-3xl"></i>
            </div>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">التحكم الإداري</h3>
            <p class="text-base text-gray-500 dark:text-gray-400 mb-6 font-bold">يرجى إدخال رمز المرور السري للتعديل</p>
            
            <input type="password" id="adminPasswordInput" placeholder="أدخل الرمز هنا..." class="w-full bg-gray-50 dark:bg-[#080A10] border border-gray-200 dark:border-ivan-darkBorder rounded-xl px-4 py-4 text-gray-900 dark:text-white focus:outline-none focus:border-ivan-red text-center text-xl tracking-widest mb-2" dir="ltr">
            <p id="adminPasswordError" class="text-ivan-red text-base font-bold opacity-0 transition-opacity mb-5">الرمز غير صحيح!</p>
            
            <div class="flex gap-3">
                <button onclick="closePasswordModal()" class="flex-1 px-4 py-4 bg-gray-200 dark:bg-[#080A10] hover:bg-gray-300 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-xl font-bold text-lg transition-all">إلغاء</button>
                <button onclick="verifyAdminPassword()" class="flex-1 px-4 py-4 bg-ivan-red hover:bg-red-700 text-white rounded-xl font-bold text-lg transition-all shadow-lg shadow-ivan-red/30">تحقق</button>
            </div>
        </div>
    </div>

    <div id="adminModal" class="fixed inset-0 bg-black/80 z-[100] hidden items-center justify-center opacity-0 transition-opacity duration-300 backdrop-blur-sm px-4">
        <div id="adminModalContent" class="bg-white dark:bg-ivan-darkCard border border-ivan-red/30 dark:border-ivan-red/50 rounded-3xl p-6 lg:p-8 max-w-sm w-full transform scale-95 transition-transform duration-300 shadow-2xl">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-2xl font-black text-gray-900 dark:text-white flex items-center gap-3">
                    <i class="fa-solid fa-lock-open text-ivan-red"></i> لوحة الإدارة
                </h3>
            </div>
            <div class="space-y-4">
                <button onclick="toggleEditMode()" class="w-full text-right px-6 py-5 bg-gray-50 dark:bg-[#080A10] hover:bg-ivan-red/10 border border-gray-200 dark:border-ivan-darkBorder hover:border-ivan-red text-gray-900 dark:text-white font-black text-lg rounded-2xl transition-all flex justify-between items-center">
                    <span>تفعيل وضع تعديل النصوص</span>
                    <i id="editIconStatus" class="fa-solid fa-pen text-ivan-red text-xl"></i>
                </button>
                <button onclick="closeAdminModal()" class="w-full text-center px-6 py-5 bg-ivan-red hover:bg-red-700 text-white font-black text-lg rounded-2xl transition-all mt-6 shadow-lg shadow-red-500/30">إغلاق اللوحة</button>
            </div>
        </div>
    </div>

    <script>
        // --- 1. الوضع المظلم (Dark Mode) ---
        function toggleTheme() {
            const html = document.documentElement;
            html.classList.toggle('dark');
            localStorage.setItem('ivanTheme', html.classList.contains('dark') ? 'dark' : 'light');
        }

        window.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem('ivanTheme') === 'light') {
                document.documentElement.classList.remove('dark');
            } else {
                document.documentElement.classList.add('dark');
            }
        });

        // --- 2. القائمة الجانبية (Sidebar) ---
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('translate-x-full');
            document.getElementById('sidebarOverlay').classList.toggle('hidden');
        }

        // --- 3. الزناد السري للإدارة (7 ضغطات متتالية) ---
        const sidebarSecretTrigger = document.getElementById('sidebarSecretTrigger');
        let clickCount = 0;
        let clickTimer;

        ['click', 'touchstart'].forEach(evt => {
            sidebarSecretTrigger.addEventListener(evt, function(e) {
                if(evt === 'touchstart') e.preventDefault(); 
                
                clickCount++;
                clearTimeout(clickTimer);
                
                clickTimer = setTimeout(() => {
                    clickCount = 0;
                }, 2000);

                if (clickCount === 7) {
                    openPasswordModal(); 
                    clickCount = 0;
                }
            });
        });

        // --- 4. نافذة كلمة سر لوحة التحكم الإدارية ---
        function openPasswordModal() {
            const modal = document.getElementById('passwordModal');
            const content = document.getElementById('passwordModalContent');
            document.getElementById('adminPasswordInput').value = '';
            document.getElementById('adminPasswordError').style.opacity = '0';
            
            modal.classList.remove('hidden');
            modal.style.display = 'flex';
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
                document.getElementById('adminPasswordInput').focus();
            }, 10);
        }

        function closePasswordModal() {
            const modal = document.getElementById('passwordModal');
            const content = document.getElementById('passwordModalContent');
            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.style.display = 'none';
                modal.classList.add('hidden');
            }, 300);
        }

        function verifyAdminPassword() {
            const pass = document.getElementById('adminPasswordInput').value.trim().toLowerCase();
            if (pass === 'admin123') { // كلمة سر لوحة التحكم للتعديل
                closePasswordModal();
                setTimeout(() => {
                    openAdminModal();
                }, 300);
            } else {
                const errorText = document.getElementById('adminPasswordError');
                errorText.style.opacity = '1';
                setTimeout(() => {
                    errorText.style.opacity = '0';
                }, 3000);
            }
        }

        document.getElementById('adminPasswordInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') verifyAdminPassword();
        });

        // --- 5. لوحة التعديل المباشر ---
        function openAdminModal() {
            const modal = document.getElementById('adminModal');
            const content = document.getElementById('adminModalContent');
            modal.classList.remove('hidden');
            modal.style.display = 'flex';
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            }, 10);
        }

        function closeAdminModal() {
            const modal = document.getElementById('adminModal');
            const content = document.getElementById('adminModalContent');
            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.style.display = 'none';
                modal.classList.add('hidden');
            }, 300);
        }

        let isEditMode = false;
        function toggleEditMode() {
            isEditMode = !isEditMode;
            const editableElements = document.querySelectorAll('.editable');
            const editIcon = document.getElementById('editIconStatus');

            if(isEditMode) {
                document.body.classList.add('edit-active');
                editableElements.forEach(el => el.contentEditable = true);
                editIcon.classList.replace('fa-pen', 'fa-check');
                editIcon.classList.replace('text-ivan-red', 'text-green-500');
                alert("🔓 تم تفعيل وضع التعديل بنجاح. اضغط على أي نص لتغييره.");
            } else {
                document.body.classList.remove('edit-active');
                editableElements.forEach(el => el.contentEditable = false);
                editIcon.classList.replace('fa-check', 'fa-pen');
                editIcon.classList.replace('text-green-500', 'text-ivan-red');
                alert("🔒 تم حفظ وإيقاف التعديل.");
            }
            closeAdminModal();
        }
    </script>
</body>
</html>
